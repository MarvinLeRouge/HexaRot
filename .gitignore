# ============================================================
# HexaRot — .gitignore
# ============================================================

# ------------------------------------------------------------
# Working documents (local only)
# ------------------------------------------------------------
docs/work-in-progress/

# ------------------------------------------------------------
# Node / npm
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json

# ------------------------------------------------------------
# Build outputs
# ------------------------------------------------------------
dist/
build/
.output/

# ------------------------------------------------------------
# Environment variables
# ------------------------------------------------------------
.env
.env.local
.env.*.local

# ------------------------------------------------------------
# NestJS
# ------------------------------------------------------------
.nest/

# ------------------------------------------------------------
# Vue / Vite
# ------------------------------------------------------------
.vite/
*.local

# ------------------------------------------------------------
# Prisma
# ------------------------------------------------------------
prisma/migrations/dev.db
prisma/*.db

# ------------------------------------------------------------
# Docker
# ------------------------------------------------------------
docker-compose.override.yml

# ------------------------------------------------------------
# OS
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# Editors
# ------------------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ------------------------------------------------------------
# Tests & coverage
# ------------------------------------------------------------
coverage/
.nyc_output/

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
logs/
*.log
